{
  "name": "gum-jsx-vscode",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/compendiumlabs/vscode-gum-jsx"
  },
  "main": "./out/extension.js",
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.19.18",
    "@types/vscode": "1.100.0",
    "gum-jsx": "^1.6.2",
    "typescript": "^5.9.3"
  },
  "activationEvents": [
    "onWebviewPanel:gumJsx.preview"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gumJsx.openPreview",
        "title": "Open Preview",
        "category": "Gum JSX",
        "icon": "$(open-preview)"
      },
      {
        "command": "gumJsx.openPreviewToSide",
        "title": "Open Preview to the Side",
        "category": "Gum JSX",
        "icon": "$(open-preview)"
      }
    ],
    "keybindings": [
      {
        "command": "gumJsx.openPreviewToSide",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == javascriptreact || editorLangId == typescriptreact || resourceExtname == .jsx"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gumJsx.openPreviewToSide",
          "when": "resourceExtname == .jsx",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "gumJsx.openPreview",
          "when": "resourceExtname == .jsx",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Gum JSX Preview",
      "properties": {
        "gumJsx.theme": {
          "type": "string",
          "enum": ["light", "dark"],
          "default": "light",
          "description": "Theme passed to gum.jsx when rendering."
        },
        "gumJsx.renderTimeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 250,
          "description": "Maximum time (ms) allowed for a gum.jsx render before stopping the worker."
        },
        "gumJsx.refreshDelayMs": {
          "type": "number",
          "default": 250,
          "minimum": 0,
          "description": "Debounce delay (ms) before re-rendering on document changes."
        }
      }
    }
  },
  "description": "Live preview for gum.jsx visualization files",
  "displayName": "Gum JSX Preview",
  "engines": {
    "vscode": "^1.100.0"
  },
  "license": "MIT",
  "publisher": "compendiumlabs",
  "scripts": {
    "build": "bun ./scripts/build.ts",
    "watch": "bun ./scripts/build.ts --watch",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json",
    "vscode:prepublish": "bun run build"
  }
}
